#!/usr/bin/env bash

# this script will install arch linux with luks2, btrfs, systemd-boot and mkinitcpio

DRY_RUN="${DRY_RUN:-1}" #dry-run always on default (1)

readonly ESP_LABEL="ARCH_ESP"
readonly ROOT_LABEL="ARCH_ROOT"

readonly ESP_PART="/dev/disk/by-partlabel/${ESP_LABEL}"
readonly ROOT_PART="/dev/disk/by-partlabel/${ROOT_LABEL}"

# ---- LUKS2 -------------------------------------------------------------------
# argon2id + aes-xts-plain64 + 512-bit key. one place, so the dry-run message
# and the real command can never drift apart.
readonly LUKS_NAME="cryptroot"
readonly LUKS_MAPPER="/dev/mapper/${LUKS_NAME}"
readonly LUKS_CIPHER="aes-xts-plain64"
readonly LUKS_KEY_SIZE="512"
readonly LUKS_HASH="sha512"
readonly LUKS_PBKDF="argon2id"

# ---- Btrfs -------------------------------------------------------------------
# top-level (subvolid=5) is mounted here only long enough to create the subvols,
# then unmounted. the real tree is built under MOUNT_ROOT from the named subvols.
readonly MOUNT_ROOT="/mnt"
readonly BTRFS_TOP="/mnt/.btrfs-top"
readonly BTRFS_OPTS="compress=zstd:1,noatime"

# ordered, pipe-delimited layout: subvol|mountpoint|extra
#   the order matters — parents before children (@ before /home, etc.)
#   extra="nocow" marks the subvol that must get chattr +C while still empty
#   (@vm: COW + VM images = fragmentation death; no compression either)
#   NOTE: no @var_lib / no subvol for /var/lib/pacman — it rides inside @ on
#   purpose, so a rollback of @ and the pacman db never desync.
readonly -a SUBVOL_LAYOUT=(
	"@|/|"
	"@home|/home|"
	"@snapshots|/.snapshots|"
	"@var_log|/var/log|"
	"@var_cache|/var/cache|"
	"@var_tmp|/var/tmp|"
	"@vm|/var/lib/libvirt/images|nocow"
)

# ---- base install ------------------------------------------------------------
# linux-hardened is the whole point; base-devel stays out of the base image.
# TTY-only host: no GPU driver, no bluetooth, no desktop. iwd (+ networkd/
# resolved, enabled in configure_system) is the whole network stack — enough
# to pull the Ansible stage. dosfstools: fsck.vfat for the ESP line genfstab
# writes, or the first boot trips on it. both ucode packages: mkinitcpio's
# microcode hook embeds the one that matches the CPU.
readonly -a PACSTRAP_PACKAGES=(
	base linux-hardened linux-firmware
	intel-ucode amd-ucode
	btrfs-progs cryptsetup dosfstools
	sbctl
	zram-generator
	iwd
	git ansible
	sudo vim
)
readonly TARGET_HOSTNAME="${TARGET_HOSTNAME:-hypervisor-01}"
readonly TARGET_TIMEZONE="${TARGET_TIMEZONE:-Europe/Rome}"
readonly TARGET_LOCALE="${TARGET_LOCALE:-en_US.UTF-8}"
readonly TARGET_KEYMAP="${TARGET_KEYMAP:-us}"

#==========================================================================================
#checks for root privileges ===============================================================
#==========================================================================================

check_root() {
	if (( EUID != 0 )); then
		echo "Permission denied: root privileges required" >&2
		return 1
	fi
	echo "[OK] Root privileges confirmed" >&2
	return 0
}

#===========================================================================================
#checks for uefi 64 bit ====================================================================
#===========================================================================================

check_uefi() {
	#checks for uefi
	if [[ ! -d /sys/firmware/efi ]]; then
		echo "Not booted in UEFI mode (BIOS/CSM?)" >&2
		return 1
	fi

	#checks for 64 bit
	local bits
	bits=$(cat /sys/firmware/efi/fw_platform_size 2>/dev/null || echo "?")

	if [[ $bits != "64" ]]; then
		echo "UEFI firmware is not 64-bit (fw_platform_size: $bits)" >&2
		return 1
	fi

	echo "[OK] 64-bit UEFI confirmed" >&2
	return 0
}

#===========================================================================================
#checks for internet connectivity (DNS + ICMP) =============================================
#===========================================================================================
check_network() {
	if ! ping -c 1 -W 3 archlinux.org > /dev/null 2>&1; then
		echo "No internet connection (or DNS failure)" >&2
		return 1
	fi
	echo "[OK] Internet connection confirmed" >&2
	return 0
}

#===========================================================================================
#interactive target disk selection==========================================================
#===========================================================================================
check_disk() {
	#checking for disks
	local -a disks
	mapfile -t disks < <(lsblk -dnpo NAME,SIZE,TYPE \
		| awk '$3 == "disk" && $1 !~ /zram/ {print $1, $2}')

	#guard: zero disks
	if (( ${#disks[@]} == 0 )); then
		echo "NO usable disks detected" >&2
		return 1
	fi

	#menu prints
	local i
	for i in "${!disks[@]}"; do
		echo "$(( i + 1 ))) ${disks[i]}" >&2
	done
	echo "0) Abort installation" >&2

	#menu loop
	local choice selected
	while true; do
		#guard to avoid infinite loop of "Invalid choice"
		if ! read -rp "Select target disk [0-${#disks[@]}]: " choice; then
			echo >&2
			echo "Input stream closed, aborting" >&2
			return 1
		fi

		#only_integers
		if [[ ! $choice =~ ^[0-9]+$ ]]; then
			echo "Invalid choice" >&2
			continue
		fi

		#base10
		choice=$(( 10#$choice ))
		if (( choice == 0 )); then
			echo "Installation aborted by user" >&2
			return 1
		fi

		#selecting the disk
		if (( choice >= 1 && choice <= ${#disks[@]} )); then
			selected="${disks[choice - 1]%% *}"
			echo "Selected: $selected" >&2
			echo "$selected"
			return 0
		fi

		#number out of range
		echo "Invalid choice" >&2
	done
}

#============================================================================================
# cleanup: the safety net ===================================================================
# ===========================================================================================
cleanup() {
	#unmount filesystem
	umount -R "$MOUNT_ROOT" 2>/dev/null || true
	#closing the disk
	cryptsetup close "$LUKS_NAME" 2>/dev/null || true
}

# ===========================================================================================
# confirm_wipe: the gate ====================================================================
# ===========================================================================================
confirm_wipe() {
	local disk="$1"
	#guard: rejects the disk where the iso is booted
	local boot_src boot_disk
	if boot_src=$(findmnt -no SOURCE /run/archiso/bootmnt 2>/dev/null); then
		boot_disk="/dev/$(lsblk -no PKNAME "$boot_src" 2>/dev/null)"
		if [[ $disk == "$boot_disk" ]]; then
			echo "Refusing to wipe the live boot medium ($disk)" >&2
			return 1
		fi
	fi

	#showing what's gonna die
	echo >&2
	echo "!!! ALL DATA ON $disk WILL BE DESTROYED !!!" >&2
	lsblk "$disk" >&2
	echo >&2

	#guard: confirm path from user
	local confirm
	if ! read -rp "Type the disk path ($disk) to confirm destruction: " confirm; then
		echo >&2
		echo "Input stream closed, aborting" >&2
		return 1
	fi

	if [[ $confirm != "$disk" ]]; then
		echo "Confirmation mismatch, aborting" >&2
		return 1
	fi
	echo "[OK] Destruction of $disk confirmed" >&2
	return 0
}

#============================================================================================
# partition_disk: sgdisk ====================================================================
#============================================================================================
partition_disk() {
	local disk="$1"

	#single source of truth for the layout: both branches use the same array
	local -a sgdisk_args=(
		--zap-all
		-n "1:0:+1G" -t "1:ef00" -c "1:${ESP_LABEL}"
		-n "2:0:0"   -t "2:8309" -c "2:${ROOT_LABEL}"
	)

	#dry-run
	if (( DRY_RUN )); then
		echo "[DRY-RUN] sgdisk in pretend mode, nothing will be written" >&2
		sgdisk --pretend "${sgdisk_args[@]}" -p "$disk" >&2 \
			|| { echo "sgdisk (pretend) failed on $disk" >&2; return 1; }
		echo "[DRY-RUN] no changes written to $disk" >&2
		return 0
	fi

	#the real stuff: every critical command checked explicitly, because
	#set -e is suspended inside functions called with || or inside if conditions
	echo "Partitioning $disk ..." >&2
	sgdisk "${sgdisk_args[@]}" "$disk" >&2 \
		|| { echo "sgdisk failed on $disk" >&2; return 1; }

	#synchronization: force kernel to reread the table, wait for udev symlinks
	partprobe "$disk" || { echo "partprobe failed on $disk" >&2; return 1; }
	udevadm settle || { echo "udevadm settle failed" >&2; return 1; }

	#guard: the by-partlabel symlinks must exist before wipefs uses them
	if [[ ! -e $ESP_PART || ! -e $ROOT_PART ]]; then
		echo "Partition symlinks did not appear after settle" >&2
		return 1
	fi

	#kill old filesystem signatures surviving inside the new partitions
	wipefs -a "$ESP_PART" "$ROOT_PART" >&2 \
		|| { echo "wipefs failed" >&2; return 1; }

	echo "[OK] $disk partitioned (ESP=$ESP_PART, ROOT=$ROOT_PART)" >&2
	return 0
}

#============================================================================================
# read_passphrase: the secret only ever travels on stdout ===================================
#============================================================================================
# reads a passphrase twice, confirms it matches, prints it (no trailing newline)
# on stdout. every prompt and every error goes to stderr, so a caller can do
#   pass=$(read_passphrase) || return 1
# and get exactly the secret, nothing else.
read_passphrase() {
	local pass1 pass2

	#-s: no echo. the prompt has to reach the terminal even with -s, hence >&2
	if ! read -rsp "LUKS passphrase: " pass1; then
		echo >&2; echo "Input stream closed" >&2; return 1
	fi
	echo >&2

	if [[ -z $pass1 ]]; then
		echo "Empty passphrase rejected" >&2
		return 1
	fi

	if ! read -rsp "Repeat passphrase: " pass2; then
		echo >&2; echo "Input stream closed" >&2; return 1
	fi
	echo >&2

	if [[ $pass1 != "$pass2" ]]; then
		echo "Passphrases do not match" >&2
		return 1
	fi

	#printf '%s' — deliberately NO trailing newline. cryptsetup reads a key file
	#byte for byte; a newline baked in here would NOT match the interactive prompt
	#sd-encrypt shows at boot, and would lock the user out of their own disk.
	printf '%s' "$pass1"
	return 0
}

#============================================================================================
# encrypt_root: LUKS2 (argon2id) ============================================================
#============================================================================================
encrypt_root() {
	local part="$1"

	#capability preconditions, in BOTH branches -----------------------------------
	#cryptsetup must be present AND actually speak argon2id: a dry-run that passes
	#on a box which can't argon2id would be a lie
	command -v cryptsetup > /dev/null \
		|| { echo "cryptsetup not found" >&2; return 1; }
	if ! cryptsetup --help 2>&1 | grep -qw argon2id; then
		echo "this cryptsetup build does not list argon2id as a PBKDF" >&2
		return 1
	fi

	#sequencing precondition: the target must exist only for a REAL format. in
	#dry-run it legitimately may not exist yet (partition_disk wrote nothing), so
	#the whole pipeline can be rehearsed end to end on a blank machine.
	if (( ! DRY_RUN )) && [[ ! -e $part ]]; then
		echo "Root partition not found: $part" >&2
		return 1
	fi

	#reformatting an existing container destroys its header and every keyslot;
	#the user must be told before they type a passphrase
	if [[ -e $part ]] && cryptsetup isLuks "$part" 2>/dev/null; then
		echo "WARNING: $part already holds a LUKS header" >&2
		echo "         luksFormat will destroy it and all of its keyslots" >&2
	fi

	#the exact command both branches talk about, defined once
	local -a fmt_args=(
		luksFormat
		--type luks2
		--cipher   "$LUKS_CIPHER"
		--key-size "$LUKS_KEY_SIZE"
		--hash     "$LUKS_HASH"
		--pbkdf    "$LUKS_PBKDF"
		--batch-mode
		--key-file -
	)

	#acquire + confirm the passphrase in the dry-run too. this is deliberate: the
	#match logic is the one thing a dry-run CAN prove before a byte is written, and
	#getting it wrong is exactly what wastes a real, slow luksFormat.
	local passphrase
	passphrase=$(read_passphrase) || return 1

	#dry-run: describe, touch nothing ---------------------------------------------
	if (( DRY_RUN )); then
		echo "[DRY-RUN] would run:" >&2
		echo "          cryptsetup ${fmt_args[*]} $part" >&2
		[[ -e $part ]] \
			|| echo "[DRY-RUN] note: $part does not exist yet (partition_disk would create it)" >&2
		echo "[DRY-RUN] passphrase acquired and confirmed (${#passphrase} chars), not used" >&2
		echo "[DRY-RUN] no header written to $part" >&2
		return 0
	fi

	#real: set -e is suspended here, so each critical command guards itself --------
	echo "Formatting $part as LUKS2 ($LUKS_PBKDF) ..." >&2
	printf '%s' "$passphrase" | cryptsetup "${fmt_args[@]}" "$part" \
		|| { echo "luksFormat failed on $part" >&2; return 1; }

	echo "Opening $part as $LUKS_NAME ..." >&2
	printf '%s' "$passphrase" | cryptsetup open --key-file - "$part" "$LUKS_NAME" \
		|| { echo "luksOpen failed on $part" >&2; return 1; }

	#the mapper node is the contract handed to the btrfs phase
	if [[ ! -e $LUKS_MAPPER ]]; then
		echo "$LUKS_MAPPER did not appear after open" >&2
		return 1
	fi

	echo "[OK] $part encrypted and opened at $LUKS_MAPPER" >&2
	return 0
}

#============================================================================================
# make_filesystems: mkfs on ESP + the opened LUKS mapper ====================================
#============================================================================================
make_filesystems() {
	#capability preconditions, in both branches
	command -v mkfs.fat   > /dev/null || { echo "mkfs.fat not found" >&2; return 1; }
	command -v mkfs.btrfs > /dev/null || { echo "mkfs.btrfs not found" >&2; return 1; }

	if (( DRY_RUN )); then
		echo "[DRY-RUN] would run: mkfs.fat -F32 -n ESP $ESP_PART" >&2
		echo "[DRY-RUN] would run: mkfs.btrfs -L arch $LUKS_MAPPER" >&2
		[[ -e $ESP_PART ]] \
			|| echo "[DRY-RUN] note: $ESP_PART does not exist yet (partition_disk would create it)" >&2
		echo "[DRY-RUN] no filesystems written" >&2
		return 0
	fi

	#real: sequencing preconditions — the partition and the opened mapper
	if [[ ! -e $ESP_PART ]]; then
		echo "ESP partition not found: $ESP_PART" >&2
		return 1
	fi
	if [[ ! -e $LUKS_MAPPER ]]; then
		echo "$LUKS_MAPPER missing — was the root unlocked?" >&2
		return 1
	fi

	echo "Formatting ESP ($ESP_PART) ..." >&2
	mkfs.fat -F32 -n ESP "$ESP_PART" > /dev/null \
		|| { echo "mkfs.fat failed on $ESP_PART" >&2; return 1; }

	echo "Formatting Btrfs on $LUKS_MAPPER ..." >&2
	mkfs.btrfs -L arch "$LUKS_MAPPER" > /dev/null \
		|| { echo "mkfs.btrfs failed on $LUKS_MAPPER" >&2; return 1; }

	echo "[OK] filesystems created (ESP=vfat, root=btrfs)" >&2
	return 0
}

#============================================================================================
# validate_layout: parse the records once, refuse a malformed table =========================
#============================================================================================
# a pure check with no side effects: every phase that walks SUBVOL_LAYOUT calls
# this first, so a typo in the array dies here with a clear line, not halfway
# through mounting.
validate_layout() {
	local record subvol mount extra
	local -A seen_mount=()
	for record in "${SUBVOL_LAYOUT[@]}"; do
		IFS='|' read -r subvol mount extra <<< "$record"

		if [[ -z $subvol || -z $mount ]]; then
			echo "Malformed layout record (empty field): '$record'" >&2
			return 1
		fi
		if [[ $subvol != @* ]]; then
			echo "Subvolume name must start with '@': '$subvol'" >&2
			return 1
		fi
		if [[ $mount != /* ]]; then
			echo "Mountpoint must be absolute: '$mount'" >&2
			return 1
		fi
		if [[ -n ${seen_mount[$mount]:-} ]]; then
			echo "Duplicate mountpoint in layout: '$mount'" >&2
			return 1
		fi
		seen_mount[$mount]=1

		if [[ -n $extra && $extra != "nocow" ]]; then
			echo "Unknown layout flag '$extra' on '$subvol'" >&2
			return 1
		fi
	done
	return 0
}

#============================================================================================
# create_subvolumes: mount subvolid=5, create every @, unmount ==============================
#============================================================================================
create_subvolumes() {
	validate_layout || return 1

	if (( DRY_RUN )); then
		echo "[DRY-RUN] would mount $LUKS_MAPPER (subvolid=5) at $BTRFS_TOP" >&2
		local record subvol rest
		for record in "${SUBVOL_LAYOUT[@]}"; do
			IFS='|' read -r subvol rest <<< "$record"
			echo "[DRY-RUN]   btrfs subvolume create $BTRFS_TOP/$subvol" >&2
		done
		echo "[DRY-RUN] would unmount $BTRFS_TOP" >&2
		return 0
	fi

	if [[ ! -e $LUKS_MAPPER ]]; then
		echo "$LUKS_MAPPER missing — cannot create subvolumes" >&2
		return 1
	fi

	mkdir -p "$BTRFS_TOP" || { echo "mkdir $BTRFS_TOP failed" >&2; return 1; }
	mount -o subvolid=5 "$LUKS_MAPPER" "$BTRFS_TOP" \
		|| { echo "mount of btrfs top-level failed" >&2; return 1; }

	local record subvol rest
	for record in "${SUBVOL_LAYOUT[@]}"; do
		IFS='|' read -r subvol rest <<< "$record"
		btrfs subvolume create "$BTRFS_TOP/$subvol" > /dev/null \
			|| { echo "btrfs subvolume create $subvol failed" >&2
			     umount "$BTRFS_TOP" 2>/dev/null || true
			     return 1; }
	done

	umount "$BTRFS_TOP" || { echo "umount $BTRFS_TOP failed" >&2; return 1; }
	rmdir "$BTRFS_TOP" 2>/dev/null || true
	echo "[OK] subvolumes created" >&2
	return 0
}

#============================================================================================
# mount_layout: mount every subvol at its home, +C on @vm, ESP on /boot ======================
#============================================================================================
mount_layout() {
	validate_layout || return 1

	if (( DRY_RUN )); then
		local record subvol mount extra
		for record in "${SUBVOL_LAYOUT[@]}"; do
			IFS='|' read -r subvol mount extra <<< "$record"
			echo "[DRY-RUN] mount -o $BTRFS_OPTS,subvol=$subvol $LUKS_MAPPER $MOUNT_ROOT$mount" >&2
			[[ $extra == "nocow" ]] && echo "[DRY-RUN]   chattr +C $MOUNT_ROOT$mount (while empty)" >&2
		done
		echo "[DRY-RUN] mount $ESP_PART $MOUNT_ROOT/boot" >&2
		echo "[DRY-RUN] nothing mounted" >&2
		return 0
	fi

	if [[ ! -e $LUKS_MAPPER ]]; then
		echo "$LUKS_MAPPER missing — cannot mount layout" >&2
		return 1
	fi

	local record subvol mount extra target
	for record in "${SUBVOL_LAYOUT[@]}"; do
		IFS='|' read -r subvol mount extra <<< "$record"
		target="$MOUNT_ROOT$mount"

		mkdir -p "$target" || { echo "mkdir $target failed" >&2; return 1; }

		#@vm is nodatacow: no compression, and mounted with nodatacow so the
		#images inside inherit it. compression + COW would shred VM disk perf.
		if [[ $extra == "nocow" ]]; then
			mount -o "noatime,nodatacow,subvol=$subvol" "$LUKS_MAPPER" "$target" \
				|| { echo "mount of $subvol failed" >&2; return 1; }
			#belt and braces: set +C on the (still empty) dir explicitly, so any
			#file created here is nodatacow even if the mount option ever changes
			chattr +C "$target" 2>/dev/null || true
		else
			mount -o "$BTRFS_OPTS,subvol=$subvol" "$LUKS_MAPPER" "$target" \
				|| { echo "mount of $subvol failed" >&2; return 1; }
		fi
	done

	#the ESP lives at /boot: systemd-boot can't read btrfs, so kernel + initramfs
	#have to sit on the FAT ESP directly (matches the hypervisor-lab boot entries)
	mkdir -p "$MOUNT_ROOT/boot" || { echo "mkdir /boot failed" >&2; return 1; }
	mount "$ESP_PART" "$MOUNT_ROOT/boot" \
		|| { echo "mount of ESP at /boot failed" >&2; return 1; }

	echo "[OK] layout mounted under $MOUNT_ROOT" >&2
	return 0
}

#============================================================================================
# pacstrap_base: the base system onto the mounted tree ======================================
#============================================================================================
pacstrap_base() {
	command -v pacstrap > /dev/null || { echo "pacstrap not found (arch-install-scripts)" >&2; return 1; }

	if (( DRY_RUN )); then
		echo "[DRY-RUN] would run: pacstrap -K $MOUNT_ROOT ${PACSTRAP_PACKAGES[*]}" >&2
		return 0
	fi

	if ! mountpoint -q "$MOUNT_ROOT"; then
		echo "$MOUNT_ROOT is not a mountpoint — mount the layout first" >&2
		return 1
	fi
	
	echo "Updating archlinux-keyring on the live host..." >&2  #fix: look at the line below
	pacman -Sy --noconfirm archlinux-keyring || { echo "Failed to update keyring" >&2; return 1; } #fix: in case booting from an old arch iso
	
	echo "Installing base system (this takes a while) ..." >&2
	pacstrap -K "$MOUNT_ROOT" "${PACSTRAP_PACKAGES[@]}" \
		|| { echo "pacstrap failed" >&2; return 1; }

	echo "[OK] base system installed" >&2
	return 0
}

#============================================================================================
# generate_fstab: genfstab by UUID =========================================================
#============================================================================================
generate_fstab() {
	command -v genfstab > /dev/null || { echo "genfstab not found (arch-install-scripts)" >&2; return 1; }

	if (( DRY_RUN )); then
		echo "[DRY-RUN] would run: genfstab -U $MOUNT_ROOT >> $MOUNT_ROOT/etc/fstab" >&2
		return 0
	fi

	if [[ ! -d $MOUNT_ROOT/etc ]]; then
		echo "$MOUNT_ROOT/etc missing — run pacstrap first" >&2
		return 1
	fi

	genfstab -U "$MOUNT_ROOT" >> "$MOUNT_ROOT/etc/fstab" \
		|| { echo "genfstab failed" >&2; return 1; }
	echo "[OK] fstab generated" >&2
	return 0
}

#============================================================================================
# configure_system: locale, time, hostname, mkinitcpio (systemd + sd-encrypt) ================
#============================================================================================
# runs inside arch-chroot. the HOOKS line is the crux: systemd + sd-encrypt,
# never the legacy 'encrypt' hook — that is the whole reason the boot entry uses
# rd.luks.name and not cryptdevice.
configure_system() {
	command -v arch-chroot > /dev/null || { echo "arch-chroot not found" >&2; return 1; }

	#the mkinitcpio HOOKS this stack requires, in order. keyboard+sd-vconsole
	#before sd-encrypt so the passphrase prompt has a working keymap.
	local hooks="base systemd autodetect microcode modconf kms keyboard sd-vconsole block sd-encrypt filesystems fsck"

	if (( DRY_RUN )); then
		echo "[DRY-RUN] would set, inside $MOUNT_ROOT:" >&2
		echo "[DRY-RUN]   timezone   $TARGET_TIMEZONE" >&2
		echo "[DRY-RUN]   locale     $TARGET_LOCALE" >&2
		echo "[DRY-RUN]   hostname   $TARGET_HOSTNAME" >&2
		echo "[DRY-RUN]   keymap     $TARGET_KEYMAP" >&2
		echo "[DRY-RUN]   HOOKS=($hooks)" >&2
		echo "[DRY-RUN]   mkinitcpio -P" >&2
		echo "[DRY-RUN]   /etc/iwd/main.conf (EnableNetworkConfiguration) + 20-wired.network (DHCP)" >&2
		echo "[DRY-RUN]   systemctl enable iwd systemd-networkd systemd-resolved" >&2
		echo "[DRY-RUN]   resolv.conf -> systemd-resolved stub" >&2
		echo "[DRY-RUN]   passwd (interactive, root)" >&2
		return 0
	fi

	if [[ ! -d $MOUNT_ROOT/etc ]]; then
		echo "$MOUNT_ROOT/etc missing — run pacstrap first" >&2
		return 1
	fi

	echo "Configuring system inside chroot ..." >&2

	#timezone
	arch-chroot "$MOUNT_ROOT" ln -sf "/usr/share/zoneinfo/$TARGET_TIMEZONE" /etc/localtime \
		|| { echo "timezone link failed" >&2; return 1; }
	arch-chroot "$MOUNT_ROOT" hwclock --systohc \
		|| { echo "hwclock failed" >&2; return 1; }

	#locale — appended only if absent, so a re-run cannot stack duplicates
	if ! grep -qxF "$TARGET_LOCALE UTF-8" "$MOUNT_ROOT/etc/locale.gen"; then
		echo "$TARGET_LOCALE UTF-8" >> "$MOUNT_ROOT/etc/locale.gen" \
			|| { echo "appending to locale.gen failed" >&2; return 1; }
	fi
	arch-chroot "$MOUNT_ROOT" locale-gen \
		|| { echo "locale-gen failed" >&2; return 1; }
	echo "LANG=$TARGET_LOCALE" > "$MOUNT_ROOT/etc/locale.conf" \
		|| { echo "writing locale.conf failed" >&2; return 1; }
	echo "KEYMAP=$TARGET_KEYMAP" > "$MOUNT_ROOT/etc/vconsole.conf" \
		|| { echo "writing vconsole.conf failed" >&2; return 1; }

	#hostname
	echo "$TARGET_HOSTNAME" > "$MOUNT_ROOT/etc/hostname" \
		|| { echo "writing hostname failed" >&2; return 1; }

	#the HOOKS line — full replacement of the array in mkinitcpio.conf
	sed -i "s/^HOOKS=.*/HOOKS=($hooks)/" "$MOUNT_ROOT/etc/mkinitcpio.conf" \
		|| { echo "editing mkinitcpio.conf failed" >&2; return 1; }
	arch-chroot "$MOUNT_ROOT" mkinitcpio -P \
		|| { echo "mkinitcpio -P failed" >&2; return 1; }

	#network at first boot + a root password, or the installed system is a brick.
	#TTY stack: iwd owns wifi (iwctl) and does its own DHCP on wlan; networkd
	#covers wired DHCP; resolved owns DNS via the stub resolv.conf symlink.
	mkdir -p "$MOUNT_ROOT/etc/iwd" "$MOUNT_ROOT/etc/systemd/network" \
		|| { echo "mkdir network config dirs failed" >&2; return 1; }
	cat > "$MOUNT_ROOT/etc/iwd/main.conf" <<-IWD \
		|| { echo "writing iwd main.conf failed" >&2; return 1; }
	[General]
	EnableNetworkConfiguration=true
	IWD
	cat > "$MOUNT_ROOT/etc/systemd/network/20-wired.network" <<-NET \
		|| { echo "writing 20-wired.network failed" >&2; return 1; }
	[Match]
	Name=en*

	[Network]
	DHCP=yes
	NET
	arch-chroot "$MOUNT_ROOT" systemctl enable iwd systemd-networkd systemd-resolved \
		|| { echo "enabling network services failed" >&2; return 1; }
	rm -f "$MOUNT_ROOT/etc/resolv.conf"
	ln -sf /run/systemd/resolve/stub-resolv.conf "$MOUNT_ROOT/etc/resolv.conf" \
		|| { echo "linking resolv.conf failed" >&2; return 1; }
	echo "Set the root password for the new system:" >&2
	arch-chroot "$MOUNT_ROOT" passwd \
		|| { echo "setting root password failed" >&2; return 1; }

	echo "[OK] system configured (HOOKS include sd-encrypt)" >&2
	return 0
}

#============================================================================================
# install_bootloader: systemd-boot + a real rd.luks.name entry ==============================
#============================================================================================
# the LUKS container UUID (luksUUID of the *partition*, not the GPT PARTUUID) is
# what rd.luks.name needs. this is the live version of the hypervisor-lab boot
# profile: sd-encrypt syntax, never cryptdevice.
install_bootloader() {
	command -v bootctl > /dev/null || { echo "bootctl not found" >&2; return 1; }

	if (( DRY_RUN )); then
		echo "[DRY-RUN] would run: arch-chroot $MOUNT_ROOT bootctl install" >&2
		echo "[DRY-RUN] would derive LUKS UUID: cryptsetup luksUUID $ROOT_PART" >&2
		echo "[DRY-RUN] would write loader entry with:" >&2
		echo "[DRY-RUN]   options rd.luks.name=<UUID>=$LUKS_NAME root=$LUKS_MAPPER rootfstype=btrfs rootflags=subvol=@ rw" >&2
		return 0
	fi

	if [[ ! -e $ROOT_PART ]]; then
		echo "$ROOT_PART missing — cannot read its LUKS UUID" >&2
		return 1
	fi

	local luks_uuid
	luks_uuid=$(cryptsetup luksUUID "$ROOT_PART") \
		|| { echo "could not read LUKS UUID of $ROOT_PART" >&2; return 1; }

	arch-chroot "$MOUNT_ROOT" bootctl install \
		|| { echo "bootctl install failed" >&2; return 1; }

	#loader.conf
	cat > "$MOUNT_ROOT/boot/loader/loader.conf" <<-LOADER \
		|| { echo "writing loader.conf failed" >&2; return 1; }
	default arch-hardened.conf
	timeout 3
	console-mode max
	editor no
	LOADER

	#the entry: rd.luks.name (sd-encrypt), rootflags picks the @ subvol
	cat > "$MOUNT_ROOT/boot/loader/entries/arch-hardened.conf" <<-ENTRY \
		|| { echo "writing loader entry failed" >&2; return 1; }
	title   Arch Linux (Hardened)
	linux   /vmlinuz-linux-hardened
	initrd  /initramfs-linux-hardened.img
	options rd.luks.name=$luks_uuid=$LUKS_NAME root=$LUKS_MAPPER rootfstype=btrfs rootflags=subvol=@ rw
	ENTRY

	echo "[OK] systemd-boot installed, entry uses rd.luks.name=$luks_uuid" >&2
	return 0
}

#============================================================================================
# configure_zram: zram-generator, no swap partition =========================================
#============================================================================================
configure_zram() {
	if (( DRY_RUN )); then
		echo "[DRY-RUN] would write $MOUNT_ROOT/etc/systemd/zram-generator.conf (zram0, min(ram,8G), zstd)" >&2
		return 0
	fi

	if [[ ! -d $MOUNT_ROOT/etc/systemd ]]; then
		echo "$MOUNT_ROOT/etc/systemd missing — run pacstrap first" >&2
		return 1
	fi

	cat > "$MOUNT_ROOT/etc/systemd/zram-generator.conf" <<-ZRAM \
		|| { echo "writing zram-generator.conf failed" >&2; return 1; }
	[zram0]
	zram-size = min(ram, 8192)
	compression-algorithm = zstd
	ZRAM

	echo "[OK] zram configured (no swap partition)" >&2
	return 0
}

#============================================================================================
# main function =============================================================================
#============================================================================================
main() {
	#non interactive guards
	check_root || exit 1
	check_uefi || exit 1
	check_network || exit 1

	#capturing selected disk
	local disk # declaration and assignment separate
	disk=$(check_disk) || exit 1  #so "local" can't mask disk failure

	#check for empty string in disk
	if [[ -z $disk ]]; then
		echo "Internal error: empty disk selection" >&2
		exit 1
	fi

	echo "Target disk: $disk" >&2

	#destructive steps
	confirm_wipe "$disk"   || exit 1
	partition_disk "$disk" || exit 1

	#encryption
	encrypt_root "$ROOT_PART" || exit 1

	#filesystems + layout
	make_filesystems  || exit 1
	create_subvolumes || exit 1
	mount_layout      || exit 1

	#base system
	pacstrap_base    || exit 1
	generate_fstab   || exit 1
	configure_system || exit 1

	#boot + memory
	install_bootloader || exit 1
	configure_zram     || exit 1

	echo "[OK] installation complete — review, then reboot" >&2
	
	trap - EXIT #fix: prevent premature unmount of disks on successful run

}

#============================================================================================
# launcher ==================================================================================
# ===========================================================================================
# Execute main only when script is launched not when sourced, so it's possible to use "source
# installer" in a shell and test every single function in isolation, nice to have for tests in
# VMs
# ===========================================================================================
if [[ ${BASH_SOURCE[0]} == "$0" ]]; then
	#strict mode is enabled only here, so sourcing the script doesn't force -euo pipefail
	#onto the interactive shell
	set -euo pipefail
	shopt -s inherit_errexit

	trap cleanup EXIT
	
	main "$@"
fi
